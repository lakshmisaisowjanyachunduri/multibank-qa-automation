<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="MultiBank QA Test Suite" verbose="1" parallel="tests" thread-count="2">

    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
            <class name="com.multibank.tests.TradingTest"/>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.multibank.tests.NavigationTest"/>
            <class name="com.multibank.tests.TradingTest"/>
            <class name="com.multibank.tests.ContentValidationTest"/>
        </classes>
    </test>

</suite>